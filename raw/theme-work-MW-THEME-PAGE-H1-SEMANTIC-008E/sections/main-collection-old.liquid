{%- render 'section-spacing-collapsing' -%}

{%- if section.settings.show_filters and collection.filters.size > 0 -%}
  {%- assign show_filters = true -%}
{%- else -%}
  {%- assign show_filters = false -%}
{%- endif -%}

<style>
  {%- assign card_blends = false -%}

  {%- unless settings.background != 'rgba(0,0,0,0)' and settings.product_card_background != 'rgba(0,0,0,0)' and settings.background != settings.product_card_background -%}
    {%- assign card_blends = true -%}
  {%- endunless -%}

  #shopify-section-{{ section.id }} {
    --product-list-gap: {% if section.settings.products_per_row_mobile == '2' %}{% if card_blends %}var(--product-list-row-gap){% endif %} var(--spacing-2){% else %}var(--product-list-row-gap) var(--product-list-column-gap){% endif %};
    --product-list-items-per-row: {{ section.settings.products_per_row_mobile | times: 1 }};
    --product-list-grid: auto-flow dense / repeat(var(--product-list-items-per-row), minmax(0, 1fr));
    --product-list-promo-grid-column: span {{ section.settings.products_per_row_mobile }};

    --content-over-media-gap: var(--spacing-8);
  }

  @media screen and (min-width: 700px) {
    #shopify-section-{{ section.id }} {
      --product-list-gap: var(--product-list-row-gap) var(--product-list-column-gap);
      --product-list-items-per-row: 2;
      --product-list-promo-grid-column: span 1;
    }
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} {
      --product-list-items-per-row: {% if section.settings.filter_layout == 'sidebar' %}2{% else %}{{ section.settings.products_per_row_desktop | at_most: 3 }}{% endif %};
      --product-list-promo-grid-column: span 2;
    }
  }

  @media screen and (min-width: 1200px) {
    #shopify-section-{{ section.id }} {
      --product-list-items-per-row: {% if section.settings.filter_layout == 'sidebar' %}{{ section.settings.products_per_row_desktop | at_most: 3 }}{% else %}{{ section.settings.products_per_row_desktop }}{% endif %};
    }
  }

  @media screen and (min-width: 1400px) {
    #shopify-section-{{ section.id }} {
      --product-list-items-per-row: {{ section.settings.products_per_row_desktop }};
    }

    {%- for block in section.blocks -%}
      #block-{{ section.id }}-{{ block.id }} {
        --product-list-promo-grid-column: span {{ block.settings.column_span }};

        {%- if block.settings.column_span == '2' -%}
          --content-over-media-column-gap: var(--spacing-12);
        {%- endif -%}
      }
    {%- endfor -%}
  }
</style>

<div class="container">
  {%- if collection.all_products_count == 0 -%}
    <div class="empty-state">
      <div class="empty-state__icon-wrapper">
        {%- render 'icon' with 'picto-stop', width: 32, height: 32, stroke_width: 1 -%}
        <span class="count-bubble count-bubble--lg">0</span>
      </div>

      <div class="prose">
        <p class="h4">{{ 'collection.general.empty_collection' | t }}</p>

        {%- assign button_content = 'collection.general.continue_shopping' | t -%}
        {%- render 'button', href: routes.all_products_collection_url, size: 'xl', content: button_content -%}
      </div>
    </div>
  {%- else -%}
    {% if section.settings.infinite_scroll %}
      {% paginate collection.products by section.settings.products_per_page %}
        <div class="collection {% if show_filters %}collection--filters-{{ section.settings.filter_layout | escape }}{% endif %}">
          {%- if show_filters or section.settings.show_sort_by -%}
            {%- comment -%}
              IMPLEMENTATION NOTE: we have to output the drawer no matter what, as it is used on mobile (all the time) or desktop (when in drawer mode)
            {%- endcomment -%}

            <facet-drawer header-bordered id="facets-drawer" class="facets-drawer drawer" open-from="left">
              <p class="h5" slot="header">{{ 'collection.faceting.filters' | t }}</p>
              {%- render 'facets-vertical',
                results: collection,
                show_filters: true,
                show_sort_by: section.settings.show_sort_by,
                update_on_change: false
              -%}
            </facet-drawer>

            {%- if section.settings.filter_layout == 'horizontal' -%}
              {%- render 'collection-top-bar',
                results: collection,
                show_filters: show_filters,
                show_active_filters: show_filters,
                show_sort_by: section.settings.show_sort_by
              -%}
            {%- else -%}
              {%- render 'collection-top-bar',
                results: collection,
                show_filters: false,
                show_active_filters: show_filters,
                show_sort_by: section.settings.show_sort_by
              -%}
            {%- endif -%}

            {%- comment -%}We also need to render the button, that is floating on mobile{%- endcomment -%}
            {%- if show_filters -%}
              <facet-floating-filter class="facets__floating-filter md:hidden">
                {%- assign filter_label = 'collection.faceting.filter_and_sort' | t -%}
                {%- render 'button',
                  size: 'xl',
                  content: filter_label,
                  icon: 'filter',
                  style: 'fill',
                  background: settings.text_color,
                  text_color: settings.background,
                  aria_controls: 'facets-drawer'
                -%}
              </facet-floating-filter>
            {%- endif -%}
          {%- endif -%}

          {%- if show_filters and section.settings.filter_layout == 'sidebar' -%}
            <div class="collection__facets">
              <safe-sticky class="collection__facets-scroller">
                {%- render 'facets-vertical',
                  results: collection,
                  show_filters: true,
                  show_sort_by: false,
                  update_on_change: true
                -%}
              </safe-sticky>
            </div>
          {%- endif -%}

          <div class="collection__results">
            <div id="product-list">
              <!-- START PRODUCTS -->
              <div class="v-stack gap-6">
                <div class="v-stack gap-4 md:hidden">
                  {%- comment -%}We have to duplicate some information on mobile and tablet here{%- endcomment -%}
                  <p class="text-center">{{ 'collection.products_count' | t: count: collection.products_count }}</p>
                  {%- render 'active-facets', results: collection -%}
                </div>
                <reveal-items selector=".product-list > *">
                  <product-list class="product-list" role="region" aria-live="polite">
                    {% assign promotion_frequency = section.settings.promotion_frequency | default: 4 %}
                    {% assign promotion_index = 0 %}
                    {% assign block_count = section.blocks.size %}

                    {% for product in collection.products %}
                      <!-- Render product card -->
                      <div class="product" id="product-{{ forloop.index | plus: paginate.current_offset }}">
                        {%- render 'product-card', product: product, stacked: true, show_badges: true -%}
                      </div>

                      <!-- Check if the promotion block should be rendered after the specified frequency -->
                      {% assign should_display_promotion = forloop.index | modulo: promotion_frequency %}
                      {% if should_display_promotion == 0 and block_count > 0 %}
                        <!-- Determine the block to display based on the promotion index -->
                        {% assign block = section.blocks[promotion_index] %}
                        <div
                          id="block-{{ section.id }}-{{ block.id }}"
                          {% render 'surface',
                            class: 'product-list__promo group',
                            text_color: block.settings.text_color
                          %}
                          {{ block.shopify_attributes }}
                        >
                          {% if block.settings.link_url %}
                            <!-- Display promotional block as a link if link_url is present -->
                            <a
                              href="{{ block.settings.link_url }}"
                              class="content-over-media h-full rounded-sm"
                              style="--content-over-media-overlay: {{ block.settings.overlay_color.rgb }} / {{ block.settings.overlay_opacity | divided_by: 100.0 }}"
                            >
                          {% else %}
                            <!-- Display as an informative banner without a link -->
                            <div
                              class="content-over-media h-full rounded-sm flex items-center justify-center"
                              style="--content-over-media-overlay: {{ block.settings.overlay_color.rgb }} / {{ block.settings.overlay_opacity | divided_by: 100.0 }}"
                            >
                          {% endif %}

                          {%- case block.type -%}
                            {%- when 'promotion_image' -%}
                              {%- if block.settings.image != blank -%}
                                <img
                                  src="{{ block.settings.image | image_url: width: block.settings.image.width }}"
                                  loading="lazy"
                                  sizes="(max-width: 699px) 100vw, {{ 400 | times: block.settings.column_span }}px"
                                  class="zoom-image {% if block.settings.mobile_image != blank %}hidden sm:block{% endif %}"
                                  alt="{{ block.settings.title | escape }}"
                                >
                              {%- endif -%}

                              {%- if block.settings.mobile_image != blank -%}
                                <img
                                  src="{{ block.settings.mobile_image | image_url: width: block.settings.mobile_image.width }}"
                                  loading="lazy"
                                  class="zoom-image sm:hidden"
                                  alt="{{ block.settings.title | escape }}"
                                >
                              {%- endif -%}

                            {%- when 'promotion_video' -%}
                              {%- if block.settings.video -%}
                                <video autoplay muted loop playsinline preload="metadata">
                                  <source src="{{ block.settings.video | file_url }}" type="video/mp4">
                                </video>
                              {%- else -%}
                                <iframe
                                  src="{{ block.settings.external_video_url | url }}"
                                  allow="autoplay; encrypted-media"
                                  allowfullscreen
                                  frameborder="0"
                                ></iframe>
                              {%- endif -%}
                          {%- endcase -%}

                          <!-- Render title and content centered and larger -->
                          <div class="flex flex-col items-center text-center space-y-4">
                            {%- if block.settings.title != blank -%}
                              <p class="promotion-title {% if block.settings.link_url %}{{ block.settings.heading_tag }}{% else %}text-4xl font-bold{% endif %}">
                                {{ block.settings.title | escape }}
                              </p>
                            {%- endif -%}

                            <div class="promotion-text {% if block.settings.link_url %}{{ block.settings.heading_tag }}{% else %}text-2xl font-semibold{% endif %}">
                              {{ block.settings.content }}
                            </div>

                            <!-- Display 'View All' only if there is a link -->
                            {% if block.settings.link_url and block.settings.link_text != blank %}
                              <div style="justify-content: center;" class="h-stack gap-4">
                                <span class="bold">{{ block.settings.link_text | escape }}</span>
                                <div class="circle-button circle-button--sm ring-current">
                                  <span class="sr-only">{{ 'general.accessibility.previous' | t }}</span>
                                  <span class="animated-arrow"></span>
                                </div>
                              </div>
                            {% endif %}
                          </div>
                          <style>
                            .promotion-title {
                              font-size: 27px; /* Default font size for mobile */
                            }

                            /* Media query for desktop */
                            @media (min-width: 1024px) {
                              /* Adjust the min-width based on your design breakpoints */
                              .promotion-title {
                                font-size: 35px; /* Font size for desktop */
                              }
                            }
                            .promotion-text {
                              font-size: 27px; /* Default font size for mobile */
                            }

                            /* Media query for desktop */
                            @media (min-width: 1024px) {
                              /* Adjust the min-width based on your design breakpoints */
                              .promotion-text {
                                font-size: 35px; /* Font size for desktop */
                              }
                            }
                          </style>
                          {% if block.settings.link_url %}
                            </a>
                          {% else %}
                            </div>
                          {% endif %}
                        </div>

                        <!-- Increment the promotion index to cycle through available blocks -->
                        {% assign promotion_index = promotion_index | plus: 1 %}
                        {% if promotion_index >= block_count %}
                          {% assign promotion_index = 0 %}
                          <!-- Reset to start cycling blocks if all have been shown -->
                        {% endif %}
                      {% endif %}
                    {% endfor %}
                  </product-list>
                </reveal-items>
              </div>
              <!-- END PRODUCTS -->

              {% if paginate.next %}
                <!-- Hidden link to the next page, used by the infinite scroll script -->
                <a id="more" href="{{ paginate.next.url }}" style="display:none;"></a>
              {% endif %}

              <div id="product-list-foot"></div>
            </div>
          </div>
        </div>

        <!-- Include the loading spinner -->
        <div id="infinite-scroll-loader" style="display:none; text-align:center; margin-top:20px;">
          {%- render 'loading' -%}
        </div>
      {% endpaginate %}

      <script>
        document.addEventListener('DOMContentLoaded', function () {
          let isLoading = false;
          let currentURL = window.location.href;

          const initializeInfiniteScroll = () => {
            isLoading = false;
            window.addEventListener('scroll', onScroll);
          };

          const loadMoreProducts = () => {
            if (isLoading) return;
            isLoading = true;
            const loader = document.getElementById('infinite-scroll-loader');
            loader.style.display = 'block'; // Show the loading spinner

            const nextPageLink = document.getElementById('more');
            if (!nextPageLink) {
              loader.style.display = 'none'; // Hide the loading spinner if there's no next page link
              return;
            }

            let scrollURL = nextPageLink.href;

            fetch(scrollURL)
              .then((response) => {
                if (!response.ok) {
                  throw new Error(`HTTP error! status: ${response.status}`);
                }
                return response.text();
              })
              .then((html) => {
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');

                const newProductList = document.querySelector('#product-list product-list');

                const newProducts = doc.querySelectorAll('.product');
                if (newProducts.length > 0) {
                  newProducts.forEach((product) => newProductList.appendChild(product));

                  // Update the next page link
                  const newMoreLink = doc.getElementById('more');
                  if (newMoreLink) {
                    nextPageLink.href = newMoreLink.href;
                  } else {
                    window.removeEventListener('scroll', onScroll);
                    loader.style.display = 'none'; // Hide the loading spinner if no more pages are left
                  }
                } else {
                  window.removeEventListener('scroll', onScroll);
                  loader.style.display = 'none'; // Hide the loading spinner if no products are found
                }

                isLoading = false;
              })
              .catch((err) => {
                isLoading = false;
                loader.style.display = 'none'; // Hide the loading spinner on error
              });
          };

          const onScroll = () => {
            const productList = document.querySelector('#product-list product-list');
            const productListBottom = productList.getBoundingClientRect().bottom;
            const windowHeight = window.innerHeight;

            if (productListBottom <= windowHeight) {
              loadMoreProducts();
            }
          };

          const checkURLChange = () => {
            if (currentURL !== window.location.href) {
              currentURL = window.location.href;
              window.removeEventListener('scroll', onScroll);
              initializeInfiniteScroll();
            }
          };

          window.addEventListener('popstate', checkURLChange);
          setInterval(checkURLChange, 1000); // Check for URL change every second
          initializeInfiniteScroll();
        });
      </script>

    {% else %}
      {%- paginate collection.products by section.settings.products_per_page -%}
        <div class="collection {% if show_filters %}collection--filters-{{ section.settings.filter_layout | escape }}{% endif %}">
          {%- if show_filters or section.settings.show_sort_by -%}
            {%- comment -%}
              IMPLEMENTATION NOTE: we have to output the drawer no matter what, as it is used on mobile (all the time) or desktop (when in drawer mode)
            {%- endcomment -%}

            <facet-drawer header-bordered id="facets-drawer" class="facets-drawer drawer" open-from="left">
              <p class="h5" slot="header">{{ 'collection.faceting.filters' | t }}</p>
              {%- render 'facets-vertical',
                results: collection,
                show_filters: true,
                show_sort_by: section.settings.show_sort_by,
                update_on_change: false
              -%}
            </facet-drawer>

            {%- if section.settings.filter_layout == 'horizontal' -%}
              {%- render 'collection-top-bar',
                results: collection,
                show_filters: show_filters,
                show_active_filters: show_filters,
                show_sort_by: section.settings.show_sort_by
              -%}
            {%- else -%}
              {%- render 'collection-top-bar',
                results: collection,
                show_filters: false,
                show_active_filters: show_filters,
                show_sort_by: section.settings.show_sort_by
              -%}
            {%- endif -%}

            {%- comment -%}We also need to render the button, that is floating on mobile{%- endcomment -%}
            {%- if show_filters -%}
              <facet-floating-filter class="facets__floating-filter md:hidden">
                {%- assign filter_label = 'collection.faceting.filter_and_sort' | t -%}
                {%- render 'button',
                  size: 'xl',
                  content: filter_label,
                  icon: 'filter',
                  style: 'fill',
                  background: settings.text_color,
                  text_color: settings.background,
                  aria_controls: 'facets-drawer'
                -%}
              </facet-floating-filter>
            {%- endif -%}
          {%- endif -%}

          {%- if show_filters and section.settings.filter_layout == 'sidebar' -%}
            <div class="collection__facets">
              <safe-sticky class="collection__facets-scroller">
                {%- render 'facets-vertical',
                  results: collection,
                  show_filters: true,
                  show_sort_by: false,
                  update_on_change: true
                -%}
              </safe-sticky>
            </div>
          {%- endif -%}

          <div class="collection__results">
            {%- if collection.products_count == 0 -%}
              <div class="empty-state">
                <div class="empty-state__icon-wrapper">
                  {%- render 'icon' with 'picto-stop', width: 32, height: 32, stroke_width: 1 -%}
                  <span class="count-bubble count-bubble--lg">0</span>
                </div>

                <div class="prose">
                  <p class="h5">{{ 'collection.faceting.no_results' | t }}</p>

                  {%- assign button_content = 'collection.faceting.clear_filters' | t -%}
                  {%- render 'button', href: collection.url, is: 'facet-link', size: 'xl', content: button_content -%}
                </div>
              </div>
            {%- else -%}
              <div class="v-stack gap-6">
                <div class="v-stack gap-4 md:hidden">
                  {%- comment -%}We have to duplicate some information on mobile and tablet here{%- endcomment -%}
                  <p class="text-center">{{ 'collection.products_count' | t: count: collection.products_count }}</p>
                  {%- render 'active-facets', results: collection -%}
                </div>

                <reveal-items selector=".product-list > *">
                  <product-list class="product-list" role="region" aria-live="polite">
                    {%- for product in collection.products -%}
                      {%- for block in section.blocks -%}
                        <!-- Check block type and position to render correctly -->
                        {{ block.settings.position }}
                        {{ forloop.index }}
                        {%- if forloop.index == block.settings.position -%}
                          <div
                            id="block-{{ section.id }}-{{ block.id }}"
                            {{ block.shopify_attributes }}
                          >
                            <a
                              {% if block.settings.link_url %}
                                href="{{ block.settings.link_url }}"
                              {% endif %}
                              class="content-over-media h-full rounded-sm"
                              style=" --content-over-media-overlay: {{ block.settings.overlay_color.rgb }} / {{ block.settings.overlay_opacity | divided_by: 100.0 }}"
                            >
                              {%- case block.type -%}
                                {%- when 'promotion_image' -%}
                                  <!-- Ensure the image is correctly set and displayed -->
                                  {%- if block.settings.image != blank -%}
                                    <img
                                      src="{{ block.settings.image | image_url: width: block.settings.image.width }}"
                                      loading="lazy"
                                      sizes="(max-width: 699px) 100vw, {{ 400 | times: block.settings.column_span }}px"
                                      class="zoom-image {% if block.settings.mobile_image != blank %}hidden sm:block{% endif %}"
                                      alt="{{ block.settings.title | escape }}"
                                    >
                                  {%- endif -%}

                                  {%- if block.settings.mobile_image != blank -%}
                                    <img
                                      src="{{ block.settings.mobile_image | image_url: width: block.settings.mobile_image.width }}"
                                      loading="lazy"
                                      class="zoom-image sm:hidden"
                                      alt="{{ block.settings.title | escape }}"
                                    >
                                  {%- endif -%}

                                {%- when 'promotion_video' -%}
                                  <!-- Render video if block is set to promotion_video -->
                                  {%- if block.settings.video -%}
                                    <video autoplay muted loop playsinline preload="metadata">
                                      <source src="{{ block.settings.video | file_url }}" type="video/mp4">
                                    </video>
                                  {%- else -%}
                                    <iframe
                                      src="{{ block.settings.external_video_url | url }}"
                                      allow="autoplay; encrypted-media"
                                      allowfullscreen
                                      frameborder="0"
                                    ></iframe>
                                  {%- endif -%}
                              {%- endcase -%}

                              <!-- Display the title and content if available -->
                              {%- if block.settings.title or block.settings.link_text -%}
                                <div class="{{ block.settings.text_position }}">
                                  <div class="v-stack gap-4 sm:gap-6">
                                    {%- if block.settings.title != blank -%}
                                      <p class="{{ block.settings.heading_tag }}">
                                        {{ block.settings.title | escape }}
                                      </p>
                                    {%- endif -%}

                                    {{ block.settings.content }}
                                    link: {{ block.settings.link_text }}
                                    {%- if block.settings.link_text -%}
                                      <div class="h-stack gap-4">
                                        <span class="bold">{{ block.settings.link_text | escape }}</span>
                                        <div class="circle-button circle-button--sm ring-current">
                                          <span class="sr-only">{{ 'general.accessibility.previous' | t }}</span>
                                          <span class="animated-arrow"></span>
                                        </div>
                                      </div>
                                    {%- endif -%}
                                  </div>
                                </div>
                              {%- endif -%}
                            </a>
                          </div>
                        {%- endif -%}
                      {%- endfor -%}

                      {%- render 'product-card', product: product, stacked: true, show_badges: true -%}
                    {%- endfor -%}
                  </product-list>
                </reveal-items>
              </div>
            {%- endif -%}
          </div>

          {%- render 'pagination', paginate: paginate, facet: true, class: 'collection__pagination' -%}
        </div>
      {%- endpaginate -%}
    {%- endif -%}
  {% endif %}
  <div class="seo-description">
    {% if section.settings.show_seo_description %}
      {{ collection.metafields.seo.description | metafield_tag }}
    {% endif %}
  </div>
</div>
<style>
  .content-over-media {
    border-radius: 25px;
  }
  .seo-description {
    justify-self: center;
  }
</style>

