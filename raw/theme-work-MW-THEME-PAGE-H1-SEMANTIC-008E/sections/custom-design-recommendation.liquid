<div
  class="custom-design-bar"
  style="background-color: {{ section.settings.background_color }}; padding: 10px 20px; display: flex; align-items: center; justify-content: space-between; border-radius: 4px;"
>
  {% assign product = all_products[section.settings.selected_product] %}
  {% if product %}
    <div class="custom-design-text">
      <h3 style="margin: 0; font-size: 1.2em; font-weight: bold;">{{ section.settings.heading }}</h3>
      <p style="margin: 0; font-size: 0.9em;">{{ section.settings.subheading }}</p>
    </div>
    <div class="custom-design-product" style="display: flex; align-items: center;">
      <img
        src="{{ product.featured_image | img_url: 'small' }}"
        alt="{{ product.title }}"
        style="height: 50px; width: auto; margin-right: 10px; border-radius: 4px;"
      >
      <a
        href="{{ product.url }}"
        class="button"
        style="padding: 8px 15px; background-color: #007bff; color: #fff; text-decoration: none; border-radius: 4px; font-size: 0.9em;"
      >
        {{ section.settings.button_text }}
      </a>
    </div>
  {% else %}
    <p>No product selected or product not found. Please configure a product in the theme editor.</p>
  {% endif %}
</div>

{% schema %}
{
  "name": "Custom Design Bar",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Have a Custom Design in Mind?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We can make it a reality for you! Check out this product for inspiration."
    },
    {
      "type": "product",
      "id": "selected_product",
      "label": "Select a Product"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View Product"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f9f9f9"
    }
  ],
  "presets": [
    {
      "name": "Custom Design Bar",
      "category": "Product"
    }
  ]
}
{% endschema %}
