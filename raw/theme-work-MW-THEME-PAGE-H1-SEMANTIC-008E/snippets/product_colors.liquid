{% if template.suffix == 'art-prints-2' or template.suffix == 'cuadros'%}
  <style>
    .variant-picker__option-values {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
  </style>
  <script>
    window.translations = {};
    window.translations.lienzo = "{{ 'general.product.lienzo' | t }}";
    window.translations.cuadro = "{{ 'general.product.cuadro' | t }}";
  </script>

  <div class="product-colors-block">
    <div class="colors-header">
      <span id="color-hovered"></span>
    </div>
    <div class="product-slider-container">
      <div class="product-options-wrapper">
        <div class="product-options-container"></div>
      </div>
    </div>
  </div>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const shopifyUrl = 'https://matchwalls.myshopify.com';
      const apiVersion = '2024-07';
      const storefrontAccessToken = '6c1b37266736e048daf81446d63baadf';

      if (window.generalProduct && window.Shopify) {
        const title = window.generalProduct.title;
        const productId = window.generalProduct.id;
        const country = window.Shopify.country || 'ES';

        console.log('Product title: ', title);
        console.log('Product ID: ', productId);
        console.log('Country: ', country);

        const graphqlQuery = `
        query AllProducts @inContext(country: ${country}) {
          products(first: 100, query: "title:'${title}'") {
            edges {
              node {
                productType
                id
                handle
                title
                descriptionHtml
                variants(first: 1) {
                  edges {
                    node {
                      id
                      sku
                      barcode
                      image {
                        originalSrc
                        altText
                      }
                      price {
                        currencyCode
                        amount
                      }
                    }
                  }
                }
                metafield(namespace: "custom", key: "t_gafas_color") {
                  value
                }
              }
            }
          }
        }
      `;

        fetch(`${shopifyUrl}/api/${apiVersion}/graphql.json`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Shopify-Storefront-Access-Token': storefrontAccessToken,
          },
          body: JSON.stringify({ query: graphqlQuery }),
        })
          .then((response) => {
            if (!response.ok) {
              throw new Error(`HTTP error! Status: ${response.status}`);
            }
            return response.json();
          })
          .then((data) => {
            const products = data.data.products.edges.map((edge) => edge.node);
            console.log('products: ', products);
            renderProductColors(products);
          })
          .catch((error) => console.error('GraphQL request failed:', error));
      } else {
        console.error('window.generalProduct or window.Shopify is not defined.');
      }
    });

    function renderProductColors(products) {
      const productColorsBlock = document.querySelector('.product-colors-block .product-options-container');
      if (productColorsBlock) {
        const productTypeContainers = {};

        products.forEach((product) => {
          if (!productTypeContainers[product.productType]) {
            const typeContainer = document.createElement('div');
            typeContainer.classList.add('product-type-container');
            typeContainer.classList.add(`product-type-${product.productType}`);

            const typeHeader = document.createElement('h2');
            let typeText;

            if (product.productType === 'Chart') {
              typeText = window.translations.cuadro;
            } else if (product.productType === 'Canvas') {
              typeText = window.translations.lienzo;
            } else {
              typeText = product.productType; // default to the productType if no match
            }

            typeHeader.innerText = typeText;
            typeContainer.appendChild(typeHeader);

            const printsOptions = document.createElement('div');
            printsOptions.classList.add('prints-options');
            typeContainer.appendChild(printsOptions);

            productColorsBlock.appendChild(typeContainer);
            productTypeContainers[product.productType] = printsOptions;
          }

          const productOption = document.createElement('a');
          productOption.classList.add('product-option');
          productOption.href = `/products/${product.handle}`;
          productOption.setAttribute('product-title', product.handle);
          productOption.setAttribute('productID', product.id);

          const variantImage = product.variants.edges[0]?.node.image;
          const img = document.createElement('img');
          if (variantImage) {
            img.src = variantImage.originalSrc;
            img.alt = variantImage.altText || product.title;
          } else {
            img.src = 'default-image-url'; // Fallback image URL
            img.alt = product.title;
          }
          img.width = 100;
          img.height = 100;
          img.classList.add('product-option-image');

          const productTitle = document.createElement('div');
          productTitle.classList.add('product-title');
          productTitle.style.display = 'none';
          productTitle.innerText = product.title;

          productOption.appendChild(img);
          productOption.appendChild(productTitle);
          productTypeContainers[product.productType].appendChild(productOption);
        });

        highlightSelectedProduct();
      }
    }
    function highlightSelectedProduct() {
      const currentUrl = window.location.href;
      const productID = window.item.ProductID;

      const productOptions = document.querySelectorAll('.product-option');
      productOptions.forEach((option) => {
        const productTitle = option.getAttribute('product-title');
        const productid = option.getAttribute('productid'); // 'gid://shopify/Product/8534078226659'
        const id = productid.match(/\d+$/)[0];
        const imgElement = option.querySelector('img');
        if (productID == id) {
          option.classList.add('selected');
          imgElement.classList.add('selected');
        } else {
          option.classList.remove('selected');
          imgElement.classList.remove('selected');
        }
      });
    }
  </script>
  <style>
    .product-option img {
      transition: opacity 0.3s, border 0.3s;
      object-fit: cover;
      width: 11rem;
      height: 3rem;
      max-width: max-content;
    }
    .product-type-container h2 {
      font-size: inherit;
    }

    .prints-options {
      display: flex;
      flex-direction: row;
      gap: 0.5rem;
    }
    .product-options-container {
      padding: 0;
      display: flex;
      flex-direction: row;
      gap: 1rem;
    }
    .product-colors-block {
      padding: 0;
    }
  </style>

{% else %}
  {%- assign contains_product = false -%}

  {%- for product_colors in block.settings.products -%}
    {%- if product_colors == product -%}
      {%- assign contains_product = true -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if contains_product -%}
    <div class="product-colors-block">
      <div class="colors-header">
        <span class="bold">{{ 'general.product.colors' | t }}</span>
        <span id="color-hovered"></span>
      </div>
      <div class="product-slider-container">
        <button class="slider-arrow left-arrow">&lt;</button>
        <div class="product-options-wrapper">
          <div class="product-options-container">
            {% for product_color in block.settings.products %}
              <a
                product-title="{{ product_color.handle }}"
                productid="{{ product_color.id }}"
                href="{{ product_color.url }}"
                class="product-option"
              >
                <img
                  {% if product_color.metafields.pdp.tester_product.value.featured_image %}
                    src="{{ product_color.metafields.pdp.tester_product.value.featured_image | image_url: width: 80, height: 80 }}"
                  {% else %}
                    src="{{ product_color.images[0] | image_url: width: 80, height: 80 }}"
                  {% endif %}
                  alt="{{ product_color.title }}"
                  width="100"
                  height="100"
                  class="product-option-image"
                >
                <div style="display: none" class="product-title">{{ product_color.title }}</div>
              </a>
            {% endfor %}
          </div>
        </div>
        <button class="slider-arrow right-arrow">&gt;</button>
      </div>
    </div>
  {% endif %}
  <style>
    .product-slider-container {
      display: flex;
      align-items: center;
      position: relative;
    }

    .product-options-wrapper {
      overflow: hidden;
      flex: 1;
    }

    .product-options-container {
      display: flex;
      transition: transform 0.3s ease;
      gap: 10px;
      padding: 10px 0;
    }

    .product-option {
      position: relative;
      cursor: pointer;
      text-decoration: none;
    }
    .product-option img {
      border-radius: 50%;
      transition: opacity 0.3s, border 0.3s;
      object-fit: cover;
      width: 11rem;
      height: 3rem;
      max-width: max-content;
    }
  </style>
  <script>
    window.product = {{ product | json }}
    document.addEventListener('DOMContentLoaded', function () {
      const leftArrow = document.querySelector('.left-arrow');
      const rightArrow = document.querySelector('.right-arrow');
      const container = document.querySelector('.product-options-container');
      const wrapper = document.querySelector('.product-options-wrapper');
      const containerWidth = container.scrollWidth;
      const colorHovered = document.getElementById('color-hovered');
      const productOptions = document.querySelectorAll('.product-option');

      leftArrow.addEventListener('click', function () {
        wrapper.scrollBy({
          left: -100,
          behavior: 'smooth',
        });
      });

      rightArrow.addEventListener('click', function () {
        wrapper.scrollBy({
          left: 100,
          behavior: 'smooth',
        });
      });

      productOptions.forEach((option) => {
        option.addEventListener('mouseover', function () {
          const title = option.querySelector('.product-title').innerText;
          colorHovered.innerText = title;
        });

        option.addEventListener('mouseout', function () {
          colorHovered.innerText = '';
        });
      });

      highlightSelectedProduct();
    });


    function highlightSelectedProduct() {
      const currentUrl = window.location.href;
      const productID = window.item.ProductID;
      const productOptions = document.querySelectorAll('.product-option');
      productOptions.forEach((option) => {
        const productTitle = option.getAttribute('product-title');
        const productid = option.getAttribute('productid'); // 'gid://shopify/Product/8534078226659'
        const id = productid.match(/\d+$/)[0];
        const imgElement = option.querySelector('img');
        if (productID == id) {
          option.classList.add('selected');
          imgElement.classList.add('selected');
        } else {
          option.classList.remove('selected');
          imgElement.classList.remove('selected');
        }
      });
    }
  </script>
{% endif %}
<style>
  .product-option-image:hover {
    transform: scale(1.05);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    background-color: rgba(255, 255, 255, 0.1);
  }
  .product-colors-block {
    padding: 10px;
  }
  #color-hovered {
    font-size: 0.8rem;
  }

  .product-title {
    position: absolute;
    bottom: 10px;
    left: 10px;
    background-color: rgba(0, 0, 0, 0.7);
    color: #fff;
    padding: 5px;
    opacity: 0;
    transition: opacity 0.5s ease-in;
    border-radius: 5px;
  }

  .product-option:hover img {
    opacity: 0.7;
  }

  .product-option:hover .product-title {
    opacity: 1;
  }

  .slider-arrow {
    background-color: #00000000;
    color: black;
    border: none;
    padding: 10px;
    cursor: pointer;
    z-index: 1;
  }

  .left-arrow {
    position: absolute;
    left: -1.9rem;
  }

  .right-arrow {
    position: absolute;
    right: -1.9rem;
  }
  .selected img {
    border: 2px solid #000;
    opacity: 1;
    border-radius: 50%;
  }
</style>
