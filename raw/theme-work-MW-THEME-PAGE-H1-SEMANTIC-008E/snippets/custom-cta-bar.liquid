<div id="shopify-section-{{ section.id }}" class="custom-cta-bar-wrapper">
  {%- assign product = all_products[block.settings.selected_product] -%}

  <!-- Custom CTA Bar -->
  <div class="custom-cta-bar">
    {% if product %}
      <div class="cta-bar-content">
        <h3 class="cta-bar-heading">{{ block.settings.heading }}</h3>
        <p class="cta-bar-description">{{ block.settings.description }}</p>
      </div>
      <div class="cta-bar-product">
        <a
          href="{{ product.url }}"
          class="cta-bar-button"
          data-product-title="{{ product.title }}"
          data-product-id="{{ product.id }}"
          data-button-text="{{ block.settings.button_text }}"
          onclick="handleCustomCTAEvent(event, this)"
        >
          {{ block.settings.button_text }}
        </a>
      </div>
    {% else %}
      <p class="cta-bar-error">
        No product selected or product not found. Please configure a product in the theme editor.
      </p>
    {% endif %}
  </div>
</div>
<style>
    .custom-cta-bar-wrapper {
    z-index: 2;
    }
    .mobile-cta-bar-wrapper {
        padding-top: 5px
    }
  /* General Styling for the Custom CTA Bar */
  .custom-cta-bar {
    padding: 5px;
    background-color: {{ block.settings.background_color }};
    padding: 15px 20px;
    border-radius: 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
    font-family: 'Arial', sans-serif;
    z-index: 2;
  }

  .cta-bar-content {
    flex: 1;
  }

  .cta-bar-heading {
    margin: 0;
    font-size: 1.5rem;
    font-weight: bold;
    color: #333;
  }

  .cta-bar-description {
    margin: 5px 0 0;
    font-size: 1rem;
    color: #666;
  }

  .cta-bar-product {
    display: flex;
    align-items: center;
  }

  .cta-bar-button {
    padding: 5px 10px;
    background-color: #453526;
    color: white;
    text-decoration: none;
    border-radius: 25px;
    font-size: 1rem;
    font-weight: bold;
    box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
    transition: background-color 0.3s ease;
  }

  .cta-bar-button:hover {
    background-color: #2c251b;
  }

  .cta-bar-error {
    font-family: 'Arial', sans-serif;
    font-size: 1rem;
    color: #666;
  }

  /* Desktop Styling */
  @media screen and (min-width: 1000px) {
    .custom-cta-bar-wrapper {
      position: sticky;
      top: 123px;
    }

    .mobile-cta-bar-wrapper {
      display: none; /* Hide mobile bar on desktop */
    }
  }

  /* Mobile Styling */
  @media screen and (max-width: 999px) {
    .cta-bar-heading {
        font-size: 15px;
        text-align: left;
    }
    .cta-bar-description {
        font-size: 12px;
        text-align: left;
    }
    .custom-cta-bar-wrapper {
      display: none; /* Hide desktop bar on mobile */
    }
    .mobile-cta-bar-wrapper .custom-cta-bar-wrapper {
        display: block
    }

    .mobile-cta-bar-wrapper {
      display: block;
    }

    .custom-cta-bar {
      flex-direction: column; /* Stack content for better readability */
      text-align: center;
      padding: 5px;
    }

    .cta-bar-content {
    }

    .cta-bar-button {
      width: 100%;
      font-size: 12px;

    }
  }
</style>

<script>
  // Function to handle the click, send the event, and delay redirection
  function handleCustomCTAEvent(event, element) {
    event.preventDefault(); // Prevent immediate redirection

    const productTitle = element.getAttribute('data-product-title');
    const productId = element.getAttribute('data-product-id');
    const buttonText = element.getAttribute('data-button-text');
    const targetUrl = element.href;

    // Push to dataLayer
    if (window.dataLayer) {
      window.dataLayer.push({
        event: 'custom_file_cta',
        event_category: 'CTA Interaction',
        event_label: productTitle,
        product_id: productId,
        button_text: buttonText,
      });
    } else {
      console.log('DataLayer not found. Event data:', {
        event: 'custom_file_cta',
        event_category: 'CTA Interaction',
        event_label: productTitle,
        product_id: productId,
        button_text: buttonText,
      });
    }

    // Delay redirection to ensure dataLayer push is registered
    setTimeout(() => {
      window.location.href = targetUrl;
    }, 300); // Adjust delay as needed (300ms is a safe default)
  }
</script>
