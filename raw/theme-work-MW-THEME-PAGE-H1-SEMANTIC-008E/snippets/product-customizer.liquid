{%- capture button_content -%}{{ 'product.general.add_to_cart_button' | t }} {%- endcapture -%}
{%- render 'external-selectors' -%}

<product-customizer
  replicate-product="{{ product.metafields.custom.replicate_product }}"
  class="product-customizer"
  data-surface="{{ product.metafields.custom.surface }}">
  {% if product.template_suffix == 'murales-custom' %}
    <div style="position: relative;">
      <input
        type="file"
        name="properties[Custom Image]"
        id="customImage"
        accept="image/*"
        open-modal
        style="
          display: block;
          width: 100%;
          opacity: 0;
          position: absolute;
          left: 0;
          top: 0;
          height: 100%;
          cursor: pointer;
          z-index: 2;
        ">
      <div class="button button--xl button--secondary" style="
          display: flex;
          align-items: center;
          justify-content: center;
          font-size: 16px;
          cursor: pointer;
          pointer-events: none;
          z-index: 1;
        ">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          height="30px"
          viewBox="0 0 24 24"
          width="30px"
          fill="#000000"
          style="margin-right: 8px;">
          <path d="M0 0h24v24H0V0z" fill="none" />
          <path d="M18 20H4V6h9V4H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-9h-2v9zm-7.79-3.17l-1.96-2.36L5.5 18h11l-3.54-4.71zM20 4V1h-2v3h-3c.01.01 0 2 0 2h3v2.99c.01.01 2 0 2 0V6h3V4h-3z" />
        </svg>
        {{ 'product.customizer.upload_image' | t }}
      </div>
    </div>

    <br>

  {% else %}
    <button class="button button--xl button--secondary" open-modal>
      {{ 'product.customizer.customize' | t }}
    </button>
  {% endif %}

  <dialog>
    <div
      id="spinnerOverlay"
      class="spinner-overlay"
      style="display: none;"></div>
    <div
      id="loadingSpinner"
      class="spinner"
      style="display:none;">
      {%- render 'logo-matchwalls.svg' -%}
    </div>
    <div class="customizer__content">
      <header>
        <div class="customizer__btns">
          <button close-modal>
            {% render 'icon' with 'navigate_back' -%}
          </button>
          <button data-action="length">
            {% render 'icon' with 'lines' -%}
            {{- 'product.customizer.show_length' | t }}
          </button>
          <button data-action="grayscale">
            {% render 'icon' with 'grayscale' %}
            {{ 'product.customizer.greyscale' | t }}
          </button>
          <button data-action="flip">
            {% render 'icon' with 'flip' %}
            {{ 'product.customizer.flip' | t }}
          </button>

          <div
            {% if product.metafields.custom.replicate_product %}
            style="display: none"
            {% endif -%}
            class="zoom-controls">
            <button id="zoom-in">{% render 'icon' with 'zoom-in' %}</button>
            <button id="zoom-out">{% render 'icon' with 'zoom-out' %}</button>
          </div>
          <button style="background-color: #e9bcc7; width: 131px" id="downloadpdf">
            <span>{%- render 'icon' with 'download-simulation' -%}</span>
            {{ 'general.customizer.download_pdf' | t }}
          </button>
        </div>
      </header>

      <div class="customizer__body">
        <div class="customizer__canvas">
          <div class="canvas__wrapper">
            <div class="canvas__width__container">
              <div class="canvas__width">
                <span>700cm</span>
              </div>
            </div>

            <div class="canvas__height__container">
              <div class="canvas__height">
                <span>700cm</span>
              </div>
            </div>
            {% assign customizer_img = product.metafields.pdp.tester_product.value %}
            {% if product.metafields.custom.replicate_product %}
              <style>
                .canvas__container {
                  position: relative;
                  overflow: hidden;
                  width: 100%;
                  height: 97%;
                }
              </style>
              <div class="canvas__container">
                <div
                  customizer="{{ customizer_img.title }}"
                  class="canvas__image canvas_product_image"
                  style="background-image:url('{{ customizer_img | image_url: width: customizer_img.featured_image.width }}"
                  id="canvas_product_image">
                  <div class="length-lines"></div>
                </div>
                <div class="selection-frame">
                  <div></div>
                  <div></div>
                  <div></div>
                  <div></div>
                  <div></div>
                  <div></div>
                  <div></div>
                  <div></div>
                  <div></div>
                </div>
              </div>
              {% assign widthdoubled = customizer_img.featured_image.width | times: 2 %}
              <style>
                /* The container that holds both the image and the selection frame */
                .canvas__container {
                  grid-area: canvas;
                  position: relative;
                  /* so the absolute .selection-frame is positioned relative to it */
                  max-width: 100%;
                  margin: auto;
                  overflow: hidden;
                  height: 410px;
                  /* adjust as needed */
                }

                /* The actual large/wide image to drag */
                .canvas__container .canvas__image {
                  height: 100%;
                  background-position: left;
                  width: {{ widthdoubled }}px;
                  background-repeat: repeat-x;
                  background-size: contain;
                  position: relative;
                  cursor: ew-resize;
                }

                .selection-frame {
                  position: sticky;
                  top: 0;
                  left: 0;
                  right: 0;
                  bottom: 0;
                  pointer-events: none;
                  /* ensures we can drag the image behind it */
                }
              </style>
            {% else %}
              <style>
                @media (min-width: 800px) {
                  .canvas__container {
                    height: 490px;
                    width: 783px;
                  }
                }
                @media (max-width: 800px) {
                  .canvas__container {
                    height: 400px;
                  }
                }
                @media (max-width: 750px) {
                  .canvas__container {
                    height: 400px;
                  }
                }
                @media (max-width: 650px) {
                  .canvas__container {
                    height: 324px;
                  }
                }
                @media (max-width: 600px) {
                  .canvas__container {
                    height: 292px;
                  }
                }
                @media (max-width: 500px) {
                  .canvas__container {
                    height: 260px;
                  }
                }
                @media (max-width: 450px) {
                  .canvas__container {
                    height: 208px;
                  }
                }
                .selection-frame {
                  position: relative;
                }
              </style>
              <div class="canvas__container">
                <div customizer="{{ customizer_img.title }}" class="canvas__image">
                  <div
                    id="canvas_product_image"
                    class="canvas_product_image"
                    width="{{ customizer_img.featured_image.width }}"
                    height="{{ customizer_img.featured_image.height }}"
                    style="background-image:url('{{ customizer_img | image_url: width: customizer_img.width }}')">
                    <div class="length-lines"></div>
                  </div>

                  <div class="selection-frame">
                    <div></div>
                    <div></div>
                    <div></div>
                    <div></div>
                    <div></div>
                    <div></div>
                    <div></div>
                    <div></div>
                    <div></div>
                  </div>
                </div>
              </div>
            {% endif %}
          </div>
        </div>
        <div class="customizer__body__container">
          <!-- Dimensions Section -->
          <div id="dimensions" class="height-width-configurador">
            <div class="dimensions-toggle">
              <span class="dimension-toggle-text">{%- render 'icon' with 'dimensions' -%}</span>
              <span id="dimension-toggle-content">
                0.00m x 0.00m = 0.00 m²</span>
            </div>
            <div class="dimensions-content">
              <button class="popup-close">✕</button>
              <div class="dimensions-pop-up-content">
                <p class="pop-up-content-title">{{ 'general.customizer.input_dimensions' | t }}</p>
                <p id="surface-calculation-customizer" class="info__container">0.00m x 0.00m = 0.00 m²</p>
                <div class="input-row-flex" style="display: none">
                  <div class="form-control">
                    <label for="centimeters" class="radio-label">
                      <input
                        type="radio"
                        id="centimeters"
                        name="measure"
                        value="cm"
                        checked>
                      {{ 'product.customizer.cm' | t }}
                    </label>
                  </div>
                  <div class="form-control">
                    <label for="in" class="radio-label">
                      <input
                        type="radio"
                        id="in"
                        name="measure"
                        value="in">
                      {{ 'product.customizer.inches' | t }}
                    </label>
                  </div>
                </div>
                <div class="form-surface-container">
                  <div class="form-surface centimeter-selector">
                    <div class="form-control">
                      <label for="width">
                        <p style="font-weight: 800; letter-spacing: 1px">↔ {{- 'product.customizer.width' | t }}</p>
                        <input
                          type="number"
                          class="input"
                          id="width"
                          min="100"
                          max="2000"
                          value="400"
                          unit="cm">
                        <span>(cm)</span>
                      </label>
                    </div>
                    <div class="form-control">
                      <label for="height">
                        <p style="font-weight: 800; letter-spacing: 1px">↕ {{- 'product.customizer.height' | t }}</p>
                        <input
                          type="number"
                          id="height"
                          class="input"
                          min="100"
                          max="2000"
                          value="290">
                        <span>(cm)</span>
                      </label>
                    </div>
                  </div>
                  <div class="form-surface-feets" style="display: none">
                    <div class="form-control-feets">
                      <label for="width">{{ 'product.customizer.width' | t }}</label>
                      <input
                        type="number"
                        class="input"
                        id="width-feet"
                        min="0"
                        max="65"
                        value="0">
                      <span>(ft)</span>
                      <input
                        type="number"
                        class="input"
                        id="width-inch"
                        min="0"
                        max="12"
                        value="0">
                      <span>(in)</span>
                    </div>
                    <div class="form-control-feets">
                      <label for="height">{{ 'product.customizer.height' | t }}</label>
                      <input
                        type="number"
                        id="height-feet"
                        class="input"
                        min="0"
                        max="65"
                        value="0">
                      <span>(ft)</span>
                      <input
                        type="number"
                        id="height-inch"
                        min="0"
                        max="12"
                        value="0">
                      <span>(in)</span>
                    </div>
                  </div>
                </div>

                <div class="warning-message">
                  <div class="warning-title">
                    <span>⚠️</span>
                    <span>{{ 'product.customizer.warning_message_label' | t }}</span>
                  </div>
                  <div class="warning-content">
                    <span>{{ 'product.customizer.warning_message' | t }}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Qualities Section -->
          <div id="qualities">
            <div class="qualities-toggle arrow-down">
              <span class="quality-toggle-label">{%- render 'icon' with 'quality' -%}</span>
              <span class="quality-toggle-text">Non Woven</span>
            </div>
            <div class="qualities-content">
              <button class="popup-close">✕</button>
              <p class="pop-up-content-title">{{ 'general.customizer.input_quality' | t }}</p>
              <div class="customizer-quality-selector"></div>
            </div>
          </div>


          <div class="checkout-container">
            <div class="info__container" style="display: none">
              <p>
                <span style="display: none" class="total-surface">100cm</span>
              </p>
              <div id="final-price-cta">
                <span class="add-to-cart-text">{%- render 'icon' with 'checkout-cart' -%}</span>
                <span class="add-to-cart-cta-label">{{ 'product.general.add_to_cart_button' | t }}</span>
                <span class="add-to-cart-arrow">{%- render 'icon' with 'navigate_next' -%}</span>
              </div>
            </div>

            <div class="total-cta">
              <div class="add-to-cart-price">
                <span>
                  {{ 'cart.order.total' | t }}
                </span>
                <span class="final-price text-on-sale" style=" font-weight: 900;"></span>
                <div>
                  <span class="compare-final-price text-subdued line-through" style="font-size: 14px"></span>
                  <span class="discount-percentage text-on-sale " style="font-size: 14px;"></span>
                </div>
              </div>
              <div>
                {%- form 'product'
                  , product
                  , id: product_form_id
                  , is: 'product-form'
                  , style: 'height: 100%; align-content: center'
                -%}
                  <input
                    type="hidden"
                    name="quantity"
                    value="1"
                    customizer-input>
                  <input
                    type="hidden"
                    name="id"
                    customizer-input
                    value="{{ product.selected_or_first_available_variant.id }}">
                  <input
                    type="hidden"
                    name="properties[_customizer]"
                    customizer-input>
                  <input
                    type="hidden"
                    name="properties[dimensions]"
                    customizer-input
                    value="100x100cm">
                  <input
                    type="hidden"
                    name="properties[greyscale]"
                    customizer-input
                    value="false">
                  {%- render 'button'
                    , content: button_content
                    , type: 'submit'
                    , secondary: true
                    , size: 'lg'
                    , id: 'mural_cta'
                    , stretch: true
                  -%}
                {%- endform -%}
              </div>
            </div>
            <div class="confidence-trust">
              <div class="trust-pilot-icon">

                <a
                  href="https://es.trustpilot.com/review/matchwalls.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  style="text-decoration: none; display: inline-block; text-align: center;">
                  <img
                    src="https://cdn.trustpilot.net/brand-assets/4.1.0/stars/stars-4.5.svg"
                    alt="Trustpilot 4.5 Stars"
                    width="130"
                    height="20">
                  <p style="font-size: 12px;
                      font-weight: 600;
                      letter-spacing: 0.5px;
                      line-height: 14px; color: #453526;">
                    {{ 'product.customizer.what_they_think' | t }}</p>
                </a>


              </div>
              <div style="display: flex; flex-direction: row; align-items: center;">
                <span>
                  <img
                    style="height: 3rem;"
                    src="https://cdn.shopify.com/s/files/1/0677/5308/3107/files/envio-gratis-04.png?v=1712656774"
                    alt="Icono de envío gratuito">
                </span>
                <div class="free-shipping-text">
                  <span class="title">{{ 'shopify.checkout.order_summary.free_shipping_discount_label' | t }}</span>
                  <span class="description">
                    {{ 'shopify.store_availability.pick_up_time.two_to_four_days' | t }}</span>
                </div>

              </div>
              {% comment %} <div class="klarna-duplicated-div"></div> {% endcomment %}
              <div class="paymnent-methods-cta">
                <p style="font-size: 15px;
                      font-weight: 800;
                      letter-spacing: 0.5px;
                      line-height: 14px; color: #453526;">
                  {{ 'general.product.secured_methods' | t }}</p>
                {%- for type in shop.enabled_payment_types -%}
                  {{- type | payment_type_svg_tag -}}
                {%- endfor -%}
              </div>

            </div>

          </div>
        </div>
      </div>
    </div>
  </dialog>
</product-customizer>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    if (window.innerWidth <= 1100) { // Only apply on mobile screens
        const checkoutContainer = document.querySelector(".checkout-container");
        const muralCtaButton = document.getElementById("mural_cta");

        if (checkoutContainer && muralCtaButton) {
            checkoutContainer.addEventListener("click", function () {
                muralCtaButton.click(); // Simulate a click on the mural CTA button
            });
        }
    }
  });


</script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const fileInput = document.getElementById('customImage');
    const canvasImageDiv = document.getElementById('canvas_product_image');
    const dialog = document.querySelector('product-customizer dialog');
    const targetContainer = document.querySelector('.customizer-quality-selector');
    const divToDuplicate = document.getElementById('div-to-duplicate');

    // Function to add click event listeners to labels
    function addLabelListeners(labels) {
      labels.forEach((label) => {
        label.addEventListener('click', function () {
          console.log('Label clicked:', this);
          handleLabelSelection(this); // Replace this with your selection logic
        });
      });
    }

    // Function to handle label selection and toggle 'selected-variant' class
    function handleLabelSelection(label) {
      const allLabels = document.querySelectorAll(
        '.variant-picker__option-values label, .customizer-quality-selector label'
      );
      allLabels.forEach((lbl) => {
        lbl.classList.remove('selected-variant');
      });
      label.classList.add('selected-variant');
      console.log('Selected variant:', label);
    }

    // Event listener for file input change
    fileInput.addEventListener('change', function () {
      // Clone the div and append it to the target container
      const duplicatedDiv = divToDuplicate.cloneNode(true);
      targetContainer.appendChild(duplicatedDiv);
      divToDuplicate.style.display = 'none';

      // Hide the variant-picker__option-info in the duplicated div
      const variantPickerOptionInfo = duplicatedDiv.querySelector('.variant-picker__option-info');
      if (variantPickerOptionInfo) {
        variantPickerOptionInfo.style.display = 'none';
      }

      // Add event listeners to the duplicated labels
      const duplicatedLabels = duplicatedDiv.querySelectorAll('.variant-picker__option-values label');
      addLabelListeners(duplicatedLabels); // Attach listeners to the new labels

      duplicatedDiv.addEventListener('change', function () {
        const productCustomizerFileInstance = document.querySelector('product-customizer');
        if (productCustomizerFileInstance) {
          productCustomizerFileInstance.update();
        } else {
          console.error('ProductCustomizerFile instance not found.');
        }
      });

      // Handle file reading and setting image in canvas
      if (fileInput.files && fileInput.files[0]) {
        const reader = new FileReader();
        reader.onload = function (e) {
          canvasImageDiv.style.backgroundImage = 'url(' + e.target.result + ')';
          dialog.showModal();
        };
        reader.readAsDataURL(fileInput.files[0]);
      }
    });

    // Initial setup: Add event listeners to the original labels
    const originalLabels = document.querySelectorAll('.variant-picker__option-values label');
    addLabelListeners(originalLabels); // Attach listeners to the original labels
  });

  window.product = {{ product | json }};

  document.addEventListener('DOMContentLoaded', function () {
    const openModalButton = document.querySelector('button[open-modal]');
    const closeModalButton = document.querySelector('button[close-modal]');
    const dialog = document.querySelector('product-customizer dialog');
    const targetContainer = document.querySelector('.customizer-quality-selector');
    const divToDuplicate = document.getElementById('div-to-duplicate');
    const originalPosition = divToDuplicate.parentNode;
    let duplicatedDiv = null;

    openModalButton.addEventListener('click', function () {
      dialog.showModal();
      duplicatedDiv = divToDuplicate.cloneNode(true);
      targetContainer.appendChild(duplicatedDiv);
      divToDuplicate.style.display = 'none';

      // Hide the variant-picker__option-info in the duplicated div
      const variantPickerOptionInfo = duplicatedDiv.querySelector('.variant-picker__option-info');
      if (variantPickerOptionInfo) {
        variantPickerOptionInfo.style.display = 'none';
      }

      duplicatedDiv.addEventListener('change', function () {
        const productCustomizerFileInstance = document.querySelector('product-customizer');
        if (productCustomizerFileInstance) {
          productCustomizerFileInstance.update();
        } else {
          console.error('ProductCustomizerFile instance not found.');
        }
      });
    });

    function closeModal() {
      dialog.close();
      if (duplicatedDiv) {
        duplicatedDiv.parentNode.removeChild(duplicatedDiv);
        divToDuplicate.style.display = '';
        duplicatedDiv = null;
      }
    }

    closeModalButton.addEventListener('click', closeModal);

    dialog.addEventListener('click', function (event) {
      if (event.target === dialog) {
        closeModal();
      }
    });
  });
  // JavaScript to toggle the warning message on mobile
  document.addEventListener('DOMContentLoaded', function () {
    const formContainer = document.querySelector('.form-surface-container');
    const warningMessage = document.querySelector('.warning-message');

    formContainer.addEventListener('click', function () {
      if (window.innerWidth <= 768) {
        // Only for mobile view
        warningMessage.style.display = 'block';
      }
    });

    // Optional: To hide the message when clicked again or elsewhere
    document.addEventListener('click', function (e) {
      if (!formContainer.contains(e.target) && !warningMessage.contains(e.target) && window.innerWidth <= 768) {
        warningMessage.style.display = 'none'; // Hide if clicked outside
      }
    });
  });
</script>
<script>
  // Ensure the window is in desktop view (example: 1024px or higher)
  if (window.innerWidth >= 1024) {
    // Get the elements
    const dimensions = document.querySelector('#dimensions');
    const qualities = document.querySelector('#qualities');
    const customizerCanvas = document.querySelector('.customizer__canvas');
    const canvasWrapper = document.querySelector('.canvas__wrapper');

    // Check if the elements exist before proceeding
    if (dimensions && qualities && customizerCanvas && canvasWrapper) {
      // Move #dimensions inside .customizer__canvas before .canvas__wrapper
      customizerCanvas.insertBefore(dimensions, canvasWrapper);

      // Move #qualities after .canvas__wrapper
      customizerCanvas.appendChild(qualities);

      // Optionally, you can remove the original elements if they exist elsewhere
      // This is not necessary because the elements are already moved, but if needed:
      // dimensions.remove();
      // qualities.remove();
    }
  }
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Handle dimensions toggle
    const dimensionsToggle = document.querySelector('.dimensions-toggle');
    const dimensionsContent = document.querySelector('.dimensions-content');
    const dimensionsClose = dimensionsContent.querySelector('.popup-close');

    dimensionsToggle.addEventListener('click', function () {
        dimensionsContent.parentElement.classList.toggle('toggle-open');
    });

    dimensionsClose.addEventListener('click', function () {
        dimensionsContent.parentElement.classList.remove('toggle-open');
    });

    // Handle qualities toggle
    const qualitiesToggle = document.querySelector('.qualities-toggle');
    const qualitiesContent = document.querySelector('.qualities-content');
    const qualitiesClose = qualitiesContent.querySelector('.popup-close');

    function updateVariantInstructions() {
    const variantInstructions = document.querySelectorAll('.customizer-quality-selector .variant-instructions');
    if (qualitiesToggle && window.innerWidth > 1024) {
        const isArrowUp = qualitiesToggle.classList.contains('arrow-up'); // Updated to check arrow-up class
        variantInstructions.forEach(instruction => {
            instruction.style.display = isArrowUp ? 'flex' : 'none';
        });
    }
  }

  qualitiesToggle.addEventListener('click', function () {
    if (window.innerWidth <= 1024) {
        console.log("Button clicked: Toggle for mobile view");
        qualitiesContent.parentElement.classList.toggle('toggle-open');
    }
  });

  // Apply the hover effect for desktop view
  if (window.innerWidth > 1024) {
    let qualitiesElement = document.querySelector("#qualities");

    qualitiesElement.addEventListener('mouseenter', function () {
        if (qualitiesElement) {
            console.log("Hovered: Expanding side panel");
            qualitiesElement.style.width = "30%";
            qualitiesToggle.classList.remove('arrow-down');
            qualitiesToggle.classList.add('arrow-up');
            updateVariantInstructions();
        }
    });

    qualitiesElement.addEventListener('mouseleave', function () {
        if (qualitiesElement) {
            console.log("Mouse left: Collapsing side panel");
            qualitiesElement.style.width = "";
            qualitiesToggle.classList.remove('arrow-up');
            qualitiesToggle.classList.add('arrow-down');
            updateVariantInstructions();
        }
    });
  }



    qualitiesClose.addEventListener('click', function () {
        qualitiesContent.parentElement.classList.remove('toggle-open');
    });

    // Observe DOM changes to update variant instructions
    const observer = new MutationObserver(() => {
        updateVariantInstructions();
    });

    observer.observe(document.body, { childList: true, subtree: true });
  });


</script>
<style>
  @media (max-height: 700px) and (min-width: 1100px) {
    .product-customizer .customizer__canvas {
      height: 82% !important;
    }
    .product-customizer .customizer-quality-selector {
      height: 450px !important;
    }
  }


  @media (max-width: 1100px) {
    .checkout-container:hover {
      transform: scale(1.05);
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    }
    .warning-message {
      display: none;
      /* Hidden by default */
      position: absolute;
      /* Positioned absolutely relative to the container */
      background-color: #fff4e5;
      color: #856404;
      border: 1px solid #ffeeba;
      padding: 15px;
