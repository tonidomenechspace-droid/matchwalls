    {% endcapture %}
    {{
      content_for_header | replace: 'hreflang="en-ES"', 'hreflang="en"' | replace: 'hreflang="zh-Hans-ES"', 'hreflang="zh"' | replace: 'hreflang="es-ES"', 'hreflang="es"' | replace: 'hreflang="fr-ES"', 'hreflang="fr"' | replace: 'hreflang="pt-ES"', 'hreflang="pt"' | replace: 'hreflang="de-ES"', 'hreflang="de"' | replace: 'hreflang="it-ES"', 'hreflang="it"' | replace: 'hreflang="el-ES"', 'hreflang="el"' | replace: 'hreflang="da-ES"', 'hreflang="da"' | replace: 'hreflang="sv-ES"', 'hreflang="sv"' | replace: 'hreflang="no-ES"', 'hreflang="no"' | replace: 'hreflang="fi-ES"', 'hreflang="fi"' | replace: 'hreflang="he-ES"', 'hreflang="he"' | replace: 'hreflang="ar-ES"', 'hreflang="ar"' | replace: 'hreflang="zh-ES"', 'hreflang="zh"' | replace: 'hreflang="hi-ES"', 'hreflang="hi"' | replace: 'hreflang="hu-ES"', 'hreflang="hu"' | replace: 'hreflang="ja-ES"', 'hreflang="ja"' | replace: 'hreflang="ko-ES"', 'hreflang="ko"' | replace: 'hreflang="ru-ES"', 'hreflang="ru"' | replace: 'hreflang="pl-ES"', 'hreflang="pl"' | replace: 'hreflang="nl-ES"', 'hreflang="nl"'
    }}

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        function checkAnchorForm() {
          if (window.location.hash === '#anchor_form') {
            scrollToForm();
          }
        }
        function scrollToForm() {
          const formElement = document.querySelector('.bcontact-373516');
          if (formElement) {
            formElement.scrollIntoView({ behavior: 'smooth' });
          }
        }
        checkAnchorForm();
        window.addEventListener('hashchange', checkAnchorForm);
      });
    </script>
    <title>
      {% if page_title == blank -%}
        {{- shop.name -}}
      {%- else -%}
        {{- page_title -}}
        {%- if current_page != 1 %}
          &ndash; {{ 'general.page' | t: page: current_page }}{% endif -%}
      {%- endif %}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon -%}
      <link rel="shortcut icon" href="{{ settings.favicon | image_url: width: 96 }}">
      <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180 }}">
    {%- endif -%}

    {%- comment -%}Few prefetch to increase performance on commonly used third-parties{%- endcomment -%}
    <link rel="preconnect" href="https://cdn.shopify.com">
    <link
      rel="preconnect"
      href="https://fonts.shopifycdn.com"
      crossorigin>
    <link rel="dns-prefetch" href="https://productreviews.shopifycdn.com">

    {%- unless settings.heading_font.system? -%}
      <link
        rel="preload"
        href="{{ settings.heading_font | font_url }}"
        as="font"
        type="font/woff2"
        crossorigin>
    {%- endunless -%}

    {%- unless settings.text_font.system? -%}
      <link
        rel="preload"
        href="{{ settings.text_font | font_url }}"
        as="font"
        type="font/woff2"
        crossorigin>
    {%- endunless -%}

    {%- render 'social-meta-tags' -%}
    {%- render 'microdata-schema' -%}
    {%- render 'css-variables' -%}
    {%- render 'js-variables' -%}

    <script type="module" src="{{ 'vendor.min.js' | asset_url }}"></script>
    <script type="module" src="{{ 'theme.js' | asset_url }}"></script>
    <script type="module" src="{{ 'analytics.js' | asset_url }}"></script>
    <script type="module" src="{{ 'sections.js' | asset_url }}"></script>
    <script>
      window.customizer = window.customizer || {};
      window.customizer.legalone = "{{ 'general.customizer.legalone' | t }}";
      window.customizer.legaltwo = "{{ 'general.customizer.legaltwo' | t }}";
    </script>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        // Use a flag to ensure the event is fired only once
        let eventFired = false;

        // Select all product-cards within the product-list
        const productCards = document.querySelectorAll('#pdp-recommendation-category .product-card');

        productCards.forEach(function (card) {
          card.addEventListener('click', function (event) {
            if (eventFired) return; // Exit if the event has already been fired

            // Prevent the default behavior of the link
            event.preventDefault();

            // Set the flag to true to prevent multiple firings
            eventFired = true;

            // Find the closest product-list to make sure we are within the correct context
            const productList = event.target.closest('#pdp-recommendation-category');
            if (productList) {
              // Get the product title from the clicked product-card
              const productTitleElement = card.querySelector('.product-card__title a');
              const productTitle = productTitleElement ? productTitleElement.textContent.trim() : 'Unknown Product';

              // Get the target URL from the product link
              const targetUrl = productTitleElement ? productTitleElement.href : '#';

              // Get the current PDP URL
              const currentPdpUrl = window.location.href;

              // Push event to the dataLayer
              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: 'view-item-recommend-pdp',
                collectionTitle: '{{ target_collection.title | escape }}',
                productTitle: productTitle,
                currentPdpUrl: currentPdpUrl,
              });

              console.log('Event clicked and dataLayer updated');

              // Add a small delay before redirecting
              setTimeout(function () {
                window.location.href = targetUrl;
              }, 300); // 300ms delay to ensure event is pushed
            }
          });
        });
      });
    </script>
    {%- if product -%}
      <script
        type="module"
        defer
        src="{{ 'customizer.js' | asset_url }}"></script>
      <script
        type="module"
        defer
        src="{{ 'jspdf.js' | asset_url }}"></script>
      <script
        type="module"
        defer
        src="{{ 'html2canvas.js' | asset_url }}"></script>
    {%- endif -%}
    {{- 'theme.css' | asset_url | stylesheet_tag: preload: true -}}
    {%- if product -%}
      {{- 'customizer.css' | asset_url | stylesheet_tag: preload: true -}}
    {%- endif -%}
  </head>

  <body class="{% if settings.show_page_transition %}page-transition{% endif %} {% if settings.zoom_image_on_hover %}zoom-image--enabled{% endif %}">
    <!-- Google Tag Manager (noscript) -->


    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-KJQSGJDV"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>

    {%- render 'shadow-dom-templates' -%}

    <a href="#main" class="skip-to-content sr-only">{{ 'general.accessibility.skip_to_content' | t }}</a>

    {%- if request.page_type != 'password' -%}
      {%- sections 'header-group' -%}
      {%- sections 'overlay-group' -%}

      {%- if settings.cart_type == 'popover' -%}
        <cart-notification-drawer open-from="bottom" class="quick-buy-drawer drawer"></cart-notification-drawer>
      {%- endif -%}
    {%- endif -%}
    {% render 'ultimate-datalayer' %}

    {%- if request.page_type == 'customers/account' or request.page_type == 'customers/order' or request.page_type == 'customers/addresses'
    -%}
      {%- section 'account-banner' -%}
    {%- endif -%}

    <main
      role="main"
      id="main"
      class="anchor">
      {{ content_for_layout }}

      {%- comment -%}
        IMPLEMENTATION NOTE: due to the very complex logic of margin/padding collapsing in Impact, the footer group is
        added into the main element to ensure that dynamic sections added into the footer group are properly laid out.
      {%- endcomment -%}
      {%- if request.page_type != 'password' -%}
        {%- sections 'footer-group' -%}
      {%- endif -%}
    </main>
    {% if product %}
      <script>
        window.addEventListener('load', function () {
          var _learnq = window._learnq || [];
          function addedToCart() {
            fetch(`${window.location.origin}/cart.js`).then((res) =>
              res
                .clone()
                .json()
                .then((data) => {
                  var cart = {
                    total_price: data.total_price / 100,
                    $value: data.total_price / 100,
                    total_discount: data.total_discount,
                    original_total_price: data.original_total_price / 100,
                    items: data.items,
                  };
                  if (item !== 'undefined') {
                    cart = Object.assign(cart, item);
                  }
                  if (klAjax) {
                    _learnq.push(['track', 'Added to Cart', cart]);
                    klAjax = false;
                  }
                })
            );
          }
          (function (ns, fetch) {
            ns.fetch = function () {
              const response = fetch.apply(this, arguments);
              response.then((res) => {
                if (`${window.location.origin}/cart/add.js`.includes(res.url) && res.url !== '') {
                  addedToCart();
                }
              });
              return response;
            };
          })(window, window.fetch);
          var klAjax = true;
          var atcButtons = document.querySelectorAll("form[action*='/cart/add'] button[type='submit']");
          for (var i = 0; i < atcButtons.length; i++) {
            atcButtons[i].addEventListener('click', function () {
              if (klAjax) {
                _learnq.push(['track', 'Added to Cart', item]);
                klAjax = false;
              }
            });
          }
        });
      </script>
    {% endif %}

    <script
      async
      type="text/javascript"
      src="https://static.klaviyo.com/onsite/js/klaviyo.js?company_id=WDReig"></script>
  </body>
</html>